DATABASE_URL=postgresql://postgres:<password>@<supabase-host>:5432/postgres
JWT_SECRET_KEY=<generate-a-long-random-secret>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=720
MAPMYINDIA_API_KEY=<mapmyindia-or-mappls-rest-api-key>
MAPMYINDIA_GEOCODE_URL=https://atlas.mapmyindia.com/api/places/geocode
REDIS_URL=redis://localhost:6379/0
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Email (SMTP) ── approval/rejection notifications to officers
# Leave SMTP_HOST blank to disable email (approval still works, just no mail sent)
# For Gmail: SMTP_HOST=smtp.gmail.com  SMTP_PORT=587  use an App Password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=DRISHTI Ops <noreply@drishti.btp>
SMTP_USE_TLS=true
